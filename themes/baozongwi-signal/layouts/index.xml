{{- $pages := where .Site.RegularPages "Type" "in" .Site.Params.mainSections -}}
{{- $notHidden := where .Site.RegularPages "Params.hidden" "!=" true -}}
{{- $filtered := ($pages | intersect $notHidden) -}}
{{- $p := .Paginate $filtered -}}
{{- "<?xml version=\"1.0\" encoding=\"UTF-8\"?>" | safeHTML -}}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ default .Site.Title .Site.Params.description }}</description>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <atom:link href="{{ .Permalink }}" rel="self" type="application/rss+xml" />

    {{- range $p.Pages -}}
    {{- $desc := .Params.description -}}
    {{- if not $desc -}}
      {{- $desc = (.Summary | plainify) -}}
    {{- end -}}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <guid>{{ .Permalink }}</guid>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <description>{{ $desc | htmlEscape }}</description>
      <content:encoded>{{ .Plain | truncate 150 | htmlEscape }}</content:encoded>
    </item>
    {{- end -}}
  </channel>
</rss>